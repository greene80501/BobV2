# Copy to .env and fill in ONE or more provider keys
# Bob auto-loads ~/.bob/.env and nearest project .env

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Kimi
KIMI_API_KEY=

# Optional: global fallback key Bob checks
BOB_API_KEY=
