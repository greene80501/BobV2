{
  "manifest_version": 3,
  "name": "bob Browser Agent",
  "version": "0.2.0",
  "description": "Extends bob AI with real Chrome browser control. bob controls your active tab; you stay in charge.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "bob Browser Agent"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
