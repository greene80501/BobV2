{
  "manifest_version": 3,
  "name": "Browser-Agent-Bob",
  "version": "0.1.0",
  "description": "Chat with Claude from a side panel via the Bob API bridge.",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "action": {
    "default_title": "Open Browser-Agent-Bob"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
